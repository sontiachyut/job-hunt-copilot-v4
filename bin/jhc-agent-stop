#!/bin/zsh
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
PLIST="$ROOT/ops/launchd/job-hunt-copilot-supervisor.plist"
FEEDBACK_PLIST="$ROOT/ops/launchd/job-hunt-copilot-feedback-sync.plist"
FOLLOWUP_PLIST="$ROOT/ops/launchd/job-hunt-copilot-followups.plist"
PYTHON_BIN="${JHC_PYTHON_BIN:-}"
if [[ -z "$PYTHON_BIN" && -x /opt/homebrew/opt/python@3.11/libexec/bin/python3 ]]; then
  PYTHON_BIN="/opt/homebrew/opt/python@3.11/libexec/bin/python3"
fi
if [[ -z "$PYTHON_BIN" && -x /opt/homebrew/bin/python3 ]]; then
  PYTHON_BIN="/opt/homebrew/bin/python3"
fi
if [[ -z "$PYTHON_BIN" ]]; then
  PYTHON_BIN="$(command -v python3 || true)"
fi
if [[ -z "$PYTHON_BIN" ]]; then
  echo "python3 not found for supervisor shutdown" >&2
  exit 127
fi

LAUNCHD_LABELS_TEXT="$("$PYTHON_BIN" - "$ROOT" <<'PY'
from pathlib import Path
import sys

from job_hunt_copilot.local_runtime import resolve_launchd_labels

labels = resolve_launchd_labels(Path(sys.argv[1]))
print(labels["supervisor"])
print(labels["feedback_sync"])
print(labels["followups"])
PY
)"
LAUNCHD_LABELS=("${(@f)LAUNCHD_LABELS_TEXT}")
LABEL="gui/$UID/${LAUNCHD_LABELS[1]}"
FEEDBACK_LABEL="gui/$UID/${LAUNCHD_LABELS[2]}"
FOLLOWUP_LABEL="gui/$UID/${LAUNCHD_LABELS[3]}"

"$PYTHON_BIN" "$ROOT/scripts/ops/control_agent.py" stop --project-root "$ROOT" --manual-command jhc-agent-stop >/dev/null

if launchctl print "$FOLLOWUP_LABEL" >/dev/null 2>&1; then
  launchctl bootout "gui/$UID" "$FOLLOWUP_PLIST" >/dev/null
  if launchctl print "$FOLLOWUP_LABEL" >/dev/null 2>&1; then
    echo "Follow-up worker stop failed: launchd job is still loaded" >&2
    exit 1
  fi
fi

if launchctl print "$FEEDBACK_LABEL" >/dev/null 2>&1; then
  launchctl bootout "gui/$UID" "$FEEDBACK_PLIST" >/dev/null
  if launchctl print "$FEEDBACK_LABEL" >/dev/null 2>&1; then
    echo "Delayed feedback sync stop failed: launchd job is still loaded" >&2
    exit 1
  fi
fi

if launchctl print "$LABEL" >/dev/null 2>&1; then
  launchctl bootout "gui/$UID" "$PLIST" >/dev/null
  if launchctl print "$LABEL" >/dev/null 2>&1; then
    echo "Supervisor stop failed: launchd job is still loaded" >&2
    exit 1
  fi
fi

echo "Job Hunt Copilot supervisor, delayed feedback sync, and follow-up worker stopped"
